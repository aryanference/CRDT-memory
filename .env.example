# ============================================================
# PCCM — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env with real secrets.
# ============================================================

# ── Core daemon ───────────────────────────────────────────
PCCM_AGENT_ID=agent-001
PCCM_GRPC_PORT=50051
CRDT_SYNC_INTERVAL_MS=50
ACTIVATION_DECAY=0.5
PREFETCH_THRESHOLD=0.85
GOSSIP_PEERS=ws://localhost:50052,ws://localhost:50053
SQLITE_PATH=./data/pccm.db

# ── API service ───────────────────────────────────────────
PCCM_DAEMON_GRPC=http://localhost:50051
REDIS_URL=redis://localhost:6379
OPENAI_API_KEY=sk-...
EMBEDDING_PROVIDER=openai        # or "local"
API_PORT=8000

# ── MCP server ────────────────────────────────────────────
PCCM_API_URL=http://localhost:8000/api

# ── UI ────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_DEMO_MODE=true              # when true, UI uses mock data for swarm tab
